	<ColorTables><ColorTable name="DropColors" cachesize="64" compare="equal"/></ColorTables>

	<Mappings>
		<PadSection name="PadSectionElement" rows="4" roles="launcherinput">
			<foreach variable="$i" count="16">
				<Pad control="pad[$i]">
					<Value control="padLEDState[$i]" param="state"/>
					<PlainValue control="padLEDAnimation[$i]" param="animation"/>
					<ColorIndex table="DropColors" control="padLEDColor[$i]" param="color"/>
				</Pad>
			</foreach>
		</PadSection>

		<Global>
			<Invoke control="navUp" onReceive="onLauncherNavigateUp"/>
			<Invoke control="navDown" onReceive="onLauncherNavigateDown"/>
			<Invoke control="navLeft" onReceive="onLauncherNavigateLeft"/>
			<Invoke control="navRight" onReceive="onLauncherNavigateRight"/>
			<Command control="stopAll" command.category="Launcher" command.name="Stop All"/>
		</Global>

		<!-- Mixer: faders->volume, mutes->mute. Encoders (knob[]) are NOT mapped here so they stay free for Control Link. -->
		<DeviceMapping device="MixerConsole" name="MixerMapping">
			<PlacementBank target="RemoteBank" pagesize="8" name="ChannelBankElement">
				<foreach variable="$ch" count="8">
					<Strip>
						<Value control="fader[$ch]" param="volume"/>
						<Toggle control="mute[$ch]" param="mute" options="momentary"/>
					</Strip>
				</foreach>
			</PlacementBank>
		</DeviceMapping>
	</Mappings>
</ControlSurface>
